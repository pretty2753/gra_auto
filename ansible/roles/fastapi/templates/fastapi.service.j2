[Unit]
Description=FastAPI Service
After=network.target

[Service]
User={{ app_user }}
WorkingDirectory={{ app_root }}

Environment="PATH={{ venv_dir }}/bin"
EnvironmentFile=/etc/fastapi/.env

ExecStart={{ venv_dir }}/bin/uvicorn main:app \
  --host 0.0.0.0 \
  --port 8000

Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target


