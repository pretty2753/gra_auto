---
- name: Create adreamin user
  user:
    name: adreamin
    shell: /bin/bash
    groups: wheel
    append: yes


- name: Create ssh directory
  file:
    path: /home/adreamin/.ssh
    state: directory
    owner: adreamin
    group: adreamin
    mode: '0700'


- name: Add authorized key
  authorized_key:
    user: adreamin
    key: "{{ lookup('file', lookup('env','HOME') + '/.ssh/id_rsa.pub') }}"


- name: Add sudoers file
  copy:
    dest: /etc/sudoers.d/adreamin
    content: |
      adreamin ALL=(ALL) NOPASSWD:ALL
    mode: '0440'