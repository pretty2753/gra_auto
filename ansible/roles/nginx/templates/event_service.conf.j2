upstream event_service {
    server localhost:8000;
    keepalive 32;
}

server {
    listen 80;

    server_name _;

    access_log /var/log/nginx/event_service/access.log;
    error_log  /var/log/nginx/event_service/error.log warn;

    root /home/adreamin/web/fastapi/event_service;
    index index.html;

    location /static/ {
        alias /home/adreamin/web/fastapi/event_service/static/;
    }

    location / {
        proxy_pass http://event_service;

        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;

        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;

        proxy_set_header X-Forwarded-Proto $scheme;
    }

    location /health {
        access_log off;
        return 200 "healthy\n";
    }
}